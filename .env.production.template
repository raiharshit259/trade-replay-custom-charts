# ================================================================
# Trade Replay — Production Environment Template
# Copy to .env and fill in real values before deployment
# ================================================================

NODE_ENV=production

# --- Backend ---
PROD_PORT=4000
PROD_CLIENT_URL=https://tradereplay.me
PROD_JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_64_CHARS

# --- DigitalOcean Managed MongoDB ---
# Get from DO dashboard → Databases → MongoDB → Connection Details
PROD_MONGO_URI=mongodb+srv://doadmin:PASSWORD@db-mongodb-REGION-CLUSTER.mongo.ondigitalocean.com/tradereplay?tls=true&authSource=admin&replicaSet=db-mongodb-REGION-CLUSTER

# --- DigitalOcean Managed Redis ---
# Get from DO dashboard → Databases → Redis → Connection Details
PROD_REDIS_URL=rediss://default:PASSWORD@db-redis-REGION-CLUSTER.ondigitalocean.com:25061

# --- Kafka (KRaft on same droplet or separate) ---
PROD_KAFKA_ENABLED=true
PROD_KAFKA_BROKERS=localhost:9092
# Leave blank for self-hosted without SASL
PROD_KAFKA_SASL_USERNAME=
PROD_KAFKA_SASL_PASSWORD=
PROD_KAFKA_SASL_MECHANISM=plain

# --- Google OAuth ---
PROD_GOOGLE_CLIENT_ID=519388948862-jgnq690fvh4ipig0ujcagbv671b8uvqh.apps.googleusercontent.com

# --- Frontend (Vercel env vars) ---
# Set these in Vercel dashboard:
#   VITE_API_URL=https://api.tradereplay.me/api
#   VITE_GOOGLE_CLIENT_ID=519388948862-...

# --- Misc ---
PROD_USD_TO_INR=83.5
PROD_ALPHA_VANTAGE_KEY=
