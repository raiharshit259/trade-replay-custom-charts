# ================================================================
# Trade Replay — Production Environment Template
# Copy to .env and fill in real values before deployment
# DO NOT commit the filled .env to version control
# ================================================================

NODE_ENV=production

# --- Backend ---
PROD_PORT=4000
PROD_CLIENT_URL=https://tradereplay.me
PROD_JWT_SECRET=

# --- MongoDB (DigitalOcean Managed or local) ---
PROD_MONGO_URI=

# --- Redis (local on droplet, password set by setup-droplet.sh) ---
PROD_REDIS_URL=redis://default:<redis-password>@127.0.0.1:6379

# --- Kafka (KRaft on same droplet) ---
PROD_KAFKA_ENABLED=true
PROD_KAFKA_BROKERS=localhost:9092
PROD_KAFKA_SASL_USERNAME=
PROD_KAFKA_SASL_PASSWORD=
PROD_KAFKA_SASL_MECHANISM=plain

# --- Google OAuth (Client ID is public, but keep in env for flexibility) ---
PROD_GOOGLE_CLIENT_ID=

# --- Frontend (set in Vercel dashboard, NOT here) ---
# VITE_API_URL=https://api.tradereplay.me/api
# VITE_GOOGLE_CLIENT_ID=<your-google-client-id>

# --- Misc ---
PROD_USD_TO_INR=83.5
PROD_ALPHA_VANTAGE_KEY=
